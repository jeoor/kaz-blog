# Multi-author auth (EdgeOne KV)
# - KV binding name used by Cloud Functions auth layer
# - Default is AUTH_KV when omitted
AUTH_KV_BINDING=AUTH_KV

# Optional: registration policy
# - If AUTH_ALLOW_OPEN_REGISTRATION is not true, second+ users need REGISTER_INVITE_CODE
REGISTER_INVITE_CODE=change-me
# AUTH_ALLOW_OPEN_REGISTRATION=false

# Optional: session lifetime in days (default: 30)
# AUTH_SESSION_DAYS=30

# Notion (do NOT expose token to client)
NOTION_TOKEN=""
NOTION_DATABASE_ID=""

# Optional: separate Notion database for moments / short posts
NOTION_MOMENTS_DATABASE_ID=""

# Optional: customize property names (defaults shown)
NOTION_PROP_SLUG=Slug
NOTION_PROP_PUBLISHED=Published
NOTION_PROP_DATE=Date
NOTION_PROP_DESCRIPTION=Description
NOTION_PROP_AUTHOR=Author
NOTION_PROP_KEYWORDS=Keywords

# Optional: title property name
# - If omitted, we fallback to Notion default "Name"
# NOTION_PROP_TITLE=Name

# Optional moments property names (defaults shown)
NOTION_MOMENTS_PROP_SLUG=Slug
NOTION_MOMENTS_PROP_PUBLISHED=Published
NOTION_MOMENTS_PROP_DATE=Date
NOTION_MOMENTS_PROP_CONTENT=Content
NOTION_MOMENTS_PROP_MOOD=Mood
NOTION_MOMENTS_PROP_TAGS=Tags
# NOTION_MOMENTS_PROP_TITLE=Name

# Optional local fallback (used only when Notion is not configured)
# GITHUB_POSTS_DIR=sampleposts

# Used by sitemap to generate absolute URLs
NEXT_PUBLIC_URL=https://your-domain.com

# Optional: server-side 7bu image host token used by Cloud Functions image proxy
# IMAGE_HOST_TOKEN=
# Optional: override image host API base (defaults to https://7bu.top/api/v1)
# IMAGE_HOST_API_BASE=https://7bu.top/api/v1
